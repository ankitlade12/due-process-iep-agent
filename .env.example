# Qwen Cloud (OpenAI-compatible). Create a key at https://home.qwencloud.com/api-keys
# Copy this file to .env and fill in your key. .env is gitignored.
DASHSCOPE_API_KEY=sk-your-key-here

# Model configuration used by the public product:
# DUE_PROCESS_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DUE_PROCESS_ORCHESTRATOR_MODEL=qwen3.7-max
DUE_PROCESS_WORKHORSE_MODEL=qwen3.7-plus
DUE_PROCESS_VISION_MODEL=qwen3.7-plus

# If you are on the Qwen Cloud Token Plan, use this base URL instead:
# DUE_PROCESS_LLM_BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# Alibaba Cloud deployment credentials (required only to deploy Function Compute).
# Prefer a dedicated, least-privilege RAM user and rotate credentials after use.
# Never commit real credential values.
ALIBABA_CLOUD_ACCESS_KEY_ID=your-alibaba-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-alibaba-access-key-secret
