# Qwen Cloud (OpenAI-compatible). Create a key at https://home.qwencloud.com/api-keys
# Copy this file to .env and fill in your key. .env is gitignored.
DASHSCOPE_API_KEY=sk-your-key-here

# Optional overrides (defaults shown):
# DUE_PROCESS_LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DUE_PROCESS_ORCHESTRATOR_MODEL=qwen3.7-max
# DUE_PROCESS_WORKHORSE_MODEL=qwen3.7-plus
# DUE_PROCESS_VISION_MODEL=qwen3.7-plus

# If you are on the Qwen Cloud Token Plan, use this base URL instead:
# DUE_PROCESS_LLM_BASE_URL=https://token-plan.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1

# Alibaba Cloud AccessKey — only needed to deploy to Function Compute (see deploy/).
# Create at the Alibaba Cloud console -> AccessKey management. Never commit real keys.
ALIBABA_CLOUD_ACCESS_KEY_ID=your-alibaba-cloud-access-key-id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-alibaba-cloud-access-key-secret

# Function Compute custom-case boundary. Generate a long random token; public
# empty requests run synthetic data, but real payloads are disabled without it.
DUE_PROCESS_API_TOKEN=replace-with-a-long-random-token

# Public HTTPS trigger URL printed after Function Compute deployment. Configure
# this on the Streamlit host so the approval button can call the cloud action.
DUE_PROCESS_FUNCTION_URL=https://replace-with-function-compute-trigger-url

# Optional approval-gated Alibaba OSS evidence storage. Use a separate,
# least-privilege identity—not the broad deployment key above.
DUE_PROCESS_OSS_BUCKET=your-private-bucket
DUE_PROCESS_OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
DUE_PROCESS_OSS_ACCESS_KEY_ID=your-limited-oss-access-key-id
DUE_PROCESS_OSS_ACCESS_KEY_SECRET=your-limited-oss-access-key-secret
